?>
<script>
(function() {
    var POLL_MS   = 15000;
    var PSL_LAYOUT = '<?= $pslLayout ?>';

    function esc(s) {
        return String(s)
            .replace(/&/g,'&amp;').replace(/</g,'&lt;')
            .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function applyScroll(container, selector) {
        setTimeout(function() {
            var els = container.querySelectorAll(selector);
            for (var k = 0; k < els.length; k++) {
                var el = els[k];
                var shift = el.scrollWidth - el.offsetWidth;
                if (shift > 4) {
                    el.style.setProperty('--psl-shift', '-' + shift + 'px');
                    el.classList.add('psl-scroll');
                } else {
                    el.classList.remove('psl-scroll');
                }
            }
        }, 100);
    }

    function renderPoster(streams, streamsEl, moreBar, moreText) {
        var visible = Math.min(streams.length, 4);
        var extra   = streams.length - visible;
        if (moreBar && moreText) {
            if (extra > 0) {
                moreText.textContent = '+ ' + extra + ' more stream' + (extra !== 1 ? 's' : '') + ' active';
                moreBar.style.display = 'block';
            } else {
                moreBar.style.display = 'none';
            }
        }

        var html = '<div class="psl-grid">';
        for (var i = 0; i < visible; i++) {
            var s = streams[i];
            var pausedTag    = s.state === 'paused' ? ' <span class="psl-paused">⏸</span>' : '';
            var bwStr        = s.bandwidth > 0 ? ' · ' + s.bandwidth + ' Mbps' : '';
            var artTag       = s.thumb
                ? '<img class="psl-art" src="' + esc(s.thumb) + '" onerror="this.style.display=\'none\'">'
                : '';
            var subtitleHtml = s.subtitle
                ? '<div class="psl-subtitle">' + esc(s.subtitle) + '</div>'
                : '';

            html += '<div class="psl-stream">'
                  +   artTag
                  +   '<div class="psl-top">'
                  +     '<div class="psl-user">' + esc(s.user) + '</div>'
                  +     '<div class="psl-device">' + esc(s.device) + pausedTag + '</div>'
                  +   '</div>'
                  +   '<div class="psl-bottom">'
                  +     '<div class="psl-title">' + esc(s.title) + '</div>'
                  +     subtitleHtml
                  +     '<div class="psl-meta">' + esc(s.decision) + bwStr + ' · ' + esc(s.location) + '</div>'
                  +     '<div class="psl-prog-wrap">'
                  +       '<div class="psl-prog-bg">'
                  +         '<div class="psl-prog-fill" style="width:' + s.percent + '%"></div>'
                  +       '</div>'
                  +       '<span class="psl-prog-time">' + esc(s.currentTime) + ' / ' + esc(s.totalTime) + '</span>'
                  +     '</div>'
                  +   '</div>'
                  + '</div>';
        }
        html += '</div>';
        streamsEl.innerHTML = html;
        applyScroll(streamsEl, '.psl-user, .psl-device, .psl-title, .psl-subtitle');
    }

    function renderSimple(streams, streamsEl, moreBar) {
        if (moreBar) moreBar.style.display = 'none';

        var html = '<div class="psl-slist">';
        for (var i = 0; i < streams.length; i++) {
            var s       = streams[i];
            var fullTitle = s.title + (s.subtitle ? ' · ' + s.subtitle : '');
            var who       = esc(s.user) + ' &middot; ' + esc(s.device)
                          + (s.state === 'paused' ? ' <span class="psl-paused">⏸</span>' : '');
            var bwStr     = s.bandwidth > 0 ? ' · ' + s.bandwidth + ' Mbps' : '';

            html += '<div class="psl-srow">'
                  +   '<div class="psl-srow-hd">'
                  +     '<div class="psl-srow-title">' + esc(fullTitle) + '</div>'
                  +     '<div class="psl-srow-who">' + who + '</div>'
                  +   '</div>'
                  +   '<div class="psl-srow-meta">' + esc(s.decision) + bwStr + ' &middot; ' + esc(s.location) + '</div>'
                  +   '<div class="psl-prog-wrap">'
                  +     '<div class="psl-prog-bg">'
                  +       '<div class="psl-prog-fill" style="width:' + s.percent + '%"></div>'
                  +     '</div>'
                  +     '<span class="psl-prog-time">' + esc(s.currentTime) + ' / ' + esc(s.totalTime) + '</span>'
                  +   '</div>'
                  + '</div>';
        }
        html += '</div>';
        streamsEl.innerHTML = html;
        applyScroll(streamsEl, '.psl-srow-title');
    }

    function render(streams) {
        var countEl   = document.getElementById('psl-count');
        var streamsEl = document.getElementById('psl-streams');
        var moreBar   = document.getElementById('psl-more-bar');
        var moreText  = document.getElementById('psl-more-text');
        if (!countEl || !streamsEl) return;

        var n = streams.length;
        countEl.textContent = n + ' Active Stream' + (n !== 1 ? 's' : '');

        var bwTotalEl = document.getElementById('psl-bw-total');
        var bwLabelEl = document.getElementById('psl-bw-label');

        if (n === 0) {
            streamsEl.innerHTML = '<span class="psl-empty">No active streams</span>';
            if (bwTotalEl) bwTotalEl.textContent = '';
            if (bwLabelEl) bwLabelEl.textContent = '';
            if (moreBar)   moreBar.style.display = 'none';
            return;
        }

        var totalBw = 0, tcCount = 0;
        for (var j = 0; j < n; j++) {
            totalBw += streams[j].bandwidth || 0;
            if ((streams[j].decision || '').indexOf('Transcode') !== -1) tcCount++;
        }
        var dpCount = n - tcCount;
        if (bwTotalEl) bwTotalEl.textContent = totalBw.toFixed(1) + ' Mbps';
        if (bwLabelEl) {
            var label = '';
            if (tcCount === 0)      label = dpCount + ' Direct Play';
            else if (dpCount === 0) label = tcCount + ' Transcoding';
            else                    label = dpCount + ' Direct · ' + tcCount + ' Transcoding';
            bwLabelEl.textContent = label;
        }

        if (PSL_LAYOUT === 'simple') {
            renderSimple(streams, streamsEl, moreBar);
        } else {
            renderPoster(streams, streamsEl, moreBar, moreText);
        }
    }

    function fetchStreams() {
        var xhr = new XMLHttpRequest();
        xhr.open('GET', '/plugins/plexstreams-lite/ajax.php?_t=' + Date.now(), true);
        xhr.onload = function() {
            if (xhr.status === 200) {
                try {
                    var data = JSON.parse(xhr.responseText);
                    if (Array.isArray(data)) {
                        render(data);
                    } else if (data && data.error) {
                        var el = document.getElementById('psl-count');
                        if (el) el.textContent = data.error === 'not_configured'
                            ? 'Not configured — visit Settings › Plex Streams'
                            : 'Error: ' + data.error;
                    }
                } catch(e) {}
            }
        };
        xhr.onerror = function() {
            var el = document.getElementById('psl-count');
            if (el) el.textContent = 'Connection error';
        };
        xhr.send();
    }

    if (window._pslInterval) clearInterval(window._pslInterval);
    window._pslInterval = setInterval(fetchStreams, POLL_MS);
    setTimeout(fetchStreams, 800);
})();
</script>
