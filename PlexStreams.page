<script>
function pslSubmit(action) {
    var host   = document.getElementById('psl-host').value.trim().replace(/\/+$/, '');
    var token  = document.getElementById('psl-token').value.trim();
    var layout = document.querySelector('input[name="psl-layout"]:checked').value;
    var notice = document.getElementById('psl-notice');

    notice.className = 'notice';
    notice.style.display = 'block';
    notice.textContent = action === 'test' ? 'Testing connection...' : 'Saving...';

    var body = new URLSearchParams({action: action, HOST: host, TOKEN: token, LAYOUT: layout, csrf_token: window.csrf_token || ''});

    fetch('/plugins/plexstreams-lite/save.php', {method: 'POST', body: body})
        .then(function(r) {
            if (!r.ok) { return Promise.reject('HTTP ' + r.status + ' ' + r.url); }
            return r.json();
        })
        .then(function(d) {
            notice.className = 'notice ' + (d.ok ? 'ok' : 'err');
            notice.textContent = d.message;
        })
        .catch(function(e) {
            notice.className = 'notice err';
            notice.textContent = 'Request failed: ' + e;
        });
}
</script>
